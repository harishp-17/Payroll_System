# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=payroll_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_key
JWT_EXPIRES_IN=8h

# SMTP (Nodemailer) - example uses Gmail SMTP with an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_company_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Company Payroll Desk

# Payslip storage
PAYSLIP_STORAGE_DIR=./storage/payslips
